# =====================================================
# NourishNet Frontend - Environment Variables
# Copy this file to .env and fill in the values
# =====================================================

# Backend REST API base URL (no trailing slash)
VITE_API_BASE_URL=http://localhost:5000/api

# Backend root URL (used for Socket.IO connection and static /uploads files)
VITE_SERVER_URL=http://localhost:5000

# =====================================================
# Firebase Cloud Messaging (Web Push) - Volunteer App
# Create a Firebase project, enable Cloud Messaging,
# and fill these values from your Firebase console.
# These are OPTIONAL - the app works fully without them,
# push notifications will simply be disabled.
# =====================================================
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_VAPID_KEY=
